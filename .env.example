# Copy this file to .env and fill in your values.
# .env is gitignored — never commit it.

# Secret used to sign NiceGUI browser sessions.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
STORAGE_SECRET=change-me

# Bearer token that MCP clients must send to connect to the MCP server.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
# Leave empty to run the MCP server unauthenticated (not recommended on a VPS).
MCP_API_KEY=change-me
